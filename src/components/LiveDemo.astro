---
interface Props {
  baseUrl?: string;
}
const { baseUrl = 'http://localhost:8300' } = Astro.props;

const registerCmd = `curl -X POST ${baseUrl}/oauth2/default/register -H "Content-Type: application/json" -d '{"client_name":"Demo","grant_types":["password","refresh_token"],"scope":"openid patient/*.* user/*.*"}'`;
const tokenCmd = `curl -X POST ${baseUrl}/oauth2/default/token -H "Content-Type: application/x-www-form-urlencoded" -d "grant_type=password" -d "client_id=CLIENT_ID" -d "client_secret=CLIENT_SECRET" -d "username=admin" -d "password=pass"`;
const createPatientFhirCmd = `curl -X POST ${baseUrl}/apis/default/fhir/Patient -H "Authorization: Bearer TOKEN" -H "Content-Type: application/fhir+json" -d '{"resourceType":"Patient","name":[{"family":"Smith","given":["John"]}],"gender":"male","birthDate":"1980-01-15"}'`;
const createPatientCustomCmd = `curl -X POST ${baseUrl}/apis/default/api/patient -H "Authorization: Bearer TOKEN" -H "Content-Type: application/json" -d '{"fname":"John","lname":"Smith","dob":"1980-01-15","sex":"Male"}'`;
const createEncounterCmd = `curl -X POST ${baseUrl}/apis/default/api/encounter -H "Authorization: Bearer TOKEN" -H "Content-Type: application/json" -d '{"patient_id":"ID","encounter_type":"office_visit","date":"2024-03-15"}'`;
const createAppointmentCmd = `curl -X POST ${baseUrl}/apis/default/api/patient/ID/appointment -H "Authorization: Bearer TOKEN" -H "Content-Type: application/json" -d '{"date":"2024-04-20","time":"14:30","reason":"Annual physical"}'`;
---

<div class="demo-wrapper">
  <div class="demo-step">
    <strong>One-time setup required:</strong> Open <code>{baseUrl}</code> in a new tab and complete the OpenEMR installation wizard (click <em>Proceed to Step 1</em>). After installation, log in. Then refresh this page — the OpenEMR portal will appear on the right.
  </div>
  <div class="demo-container">
    <div class="demo-left">
      <div class="tab-bar">
        <button class="tab-btn active" data-tab="basic-auth">Basic and Auth</button>
        <button class="tab-btn" data-tab="fhir-r4">FHIR R4</button>
        <button class="tab-btn" data-tab="custom-ops">Custom Operations</button>
      </div>

      <div id="tab-basic-auth" class="tab-content active">
        <div class="cmd-item">
          <div class="cmd-label">Health Check - FHIR CapabilityStatement</div>
          <code>curl {baseUrl}/apis/default/fhir/metadata -H "Accept: application/fhir+json"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Health Check - API Version</div>
          <code>curl {baseUrl}/apis/default/version</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">SMART on FHIR Configuration</div>
          <code>curl {baseUrl}/.well-known/smart-configuration</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Register OAuth2 Client</div>
          <code>{registerCmd}</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Get Token - Password Grant</div>
          <code>{tokenCmd}</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">End Session (Logout)</div>
          <code>curl -X GET {baseUrl}/oauth2/default/logout -H "Authorization: Bearer TOKEN"</code>
        </div>
      </div>

      <div id="tab-fhir-r4" class="tab-content">
        <div class="cmd-item">
          <div class="cmd-label">Search Patient</div>
          <code>curl {baseUrl}/apis/default/fhir/Patient -H "Authorization: Bearer TOKEN" -H "Accept: application/fhir+json"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Read Patient</div>
          <code>curl {baseUrl}/apis/default/fhir/Patient/ID -H "Authorization: Bearer TOKEN" -H "Accept: application/fhir+json"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Create Patient</div>
          <code>{createPatientFhirCmd}</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search Practitioner</div>
          <code>curl {baseUrl}/apis/default/fhir/Practitioner -H "Authorization: Bearer TOKEN" -H "Accept: application/fhir+json"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search Encounter</div>
          <code>curl "{baseUrl}/apis/default/fhir/Encounter?patient=Patient/ID" -H "Authorization: Bearer TOKEN" -H "Accept: application/fhir+json"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search Condition</div>
          <code>curl "{baseUrl}/apis/default/fhir/Condition?patient=Patient/ID" -H "Authorization: Bearer TOKEN" -H "Accept: application/fhir+json"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search Observation</div>
          <code>curl "{baseUrl}/apis/default/fhir/Observation?patient=Patient/ID" -H "Authorization: Bearer TOKEN" -H "Accept: application/fhir+json"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search Medication</div>
          <code>curl {baseUrl}/apis/default/fhir/Medication -H "Authorization: Bearer TOKEN" -H "Accept: application/fhir+json"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search AllergyIntolerance</div>
          <code>curl "{baseUrl}/apis/default/fhir/AllergyIntolerance?patient=Patient/ID" -H "Authorization: Bearer TOKEN" -H "Accept: application/fhir+json"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search Immunization</div>
          <code>curl "{baseUrl}/apis/default/fhir/Immunization?patient=Patient/ID" -H "Authorization: Bearer TOKEN" -H "Accept: application/fhir+json"</code>
        </div>
      </div>

      <div id="tab-custom-ops" class="tab-content">
        <div class="cmd-item">
          <div class="cmd-label">Get Patient List</div>
          <code>curl {baseUrl}/apis/default/api/patient -H "Authorization: Bearer TOKEN"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Create Patient (Standard API)</div>
          <code>{createPatientCustomCmd}</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search Encounters</div>
          <code>curl {baseUrl}/apis/default/api/encounter -H "Authorization: Bearer TOKEN"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Create Encounter</div>
          <code>{createEncounterCmd}</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Read SOAP Note</div>
          <code>curl {baseUrl}/apis/default/api/encounter/ID/soap_note -H "Authorization: Bearer TOKEN"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search Allergies</div>
          <code>curl {baseUrl}/apis/default/api/patient/ID/allergy -H "Authorization: Bearer TOKEN"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Create Appointment</div>
          <code>{createAppointmentCmd}</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search Insurance</div>
          <code>curl {baseUrl}/apis/default/api/patient/ID/insurance -H "Authorization: Bearer TOKEN"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Search Drugs</div>
          <code>curl {baseUrl}/apis/default/api/drug -H "Authorization: Bearer TOKEN"</code>
        </div>
        <div class="cmd-item">
          <div class="cmd-label">Get Facilities</div>
          <code>curl {baseUrl}/apis/default/api/facility -H "Authorization: Bearer TOKEN"</code>
        </div>
      </div>
    </div>

    <div class="demo-right">
      <iframe src={baseUrl} title="OpenEMR Portal" loading="lazy"sandbox="allow-same-origin allow-scripts allow-forms allow-popups allow-modals"referrerpolicy="no-referrer"></iframe>
    </div>
  </div>
</div>

<style is:global>
  .demo-step {
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
    border-radius: 6px;
    background: var(--sl-color-blue-low);
    border: 1px solid var(--sl-color-blue);
    color: var(--sl-color-text);
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .demo-step code { font-size: inherit; }
  .demo-container {
    display: flex;
    gap: 0;
    height: calc(100vh - 14rem);
    min-height: 500px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    overflow: hidden;
  }
  .demo-left {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    border-right: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-7);
  }
  .demo-right {
    flex: 1;
    overflow: hidden;
  }
  .demo-right iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
  .tab-bar {
    display: flex;
    gap: 0;
    margin-bottom: 1rem;
    border-bottom: 2px solid var(--sl-color-gray-5);
    position: sticky;
    top: 0;
    background: var(--sl-color-gray-7);
    z-index: 2;
  }
  .tab-btn {
    padding: 0.5rem 1rem;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: all 0.2s;
    font-family: inherit;
  }
  .tab-btn:hover { color: var(--sl-color-text); }
  .tab-btn.active {
    color: var(--sl-color-text-accent);
    border-bottom-color: var(--sl-color-text-accent);
  }
  .tab-content { display: none; }
  .tab-content.active { display: block; }
  .cmd-item {
    padding: 0.75rem;
    margin-bottom: 0.5rem;
    border-radius: 4px;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
  }
  .cmd-label {
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.35rem;
  }
  .cmd-item code {
    display: block;
    font-family: monospace;
    font-size: 0.8rem;
    white-space: pre-wrap;
    word-break: break-all;
    line-height: 1.5;
    color: var(--sl-color-text);
  }
</style>

<script>
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + tab).classList.add('active');
    });
  });
</script>
